function M = makeContactMatrix_PM(v)

% Function to make a proportionate mixing contact matrix from a specified
% distribution of activity levels (in discrete bins)
%
% USAGE: M = makeContactMatrix_PM(v)
%
% INPUTS: v - 1 n x vector of monotonically increaing activity levels in
% each bin
% OUTPUTS: M - n x n contact matrix whose (i,j) element is 

nBins = length(v);
dx = 1/nBins;

% Calculate mean activity level
Ev = dx*sum(v);

% Make matrix
M = dx * v'.*v/Ev;
